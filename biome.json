{
    "root": true,
    "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
    "files": {
        "includes": ["**", "!**/dist", "!**/node_modules", "!**/storybook-static"]
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "always"
        }
    },
    "css": {
        "parser": {
            "tailwindDirectives": true
        }
    }
}
